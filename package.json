{
  "name": "barbara-sh-b010-vancouver-puls",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "build:web": "npm --workspace apps/web run build",
    "preview:web": "npm --workspace apps/web run preview",
    "dev:api": "cargo run -p api",
    "build:api": "cargo build",
    "build": "npm run build:web && cargo build"
  }
}
