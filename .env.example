# Server
# Bind on 0.0.0.0:8080 for container or reverse-proxy deployments.
HOST=0.0.0.0
PORT=8080
RUST_LOG=api=info,tower_http=info
SELF_URL=https://your-domain.example
ALLOWED_CORS_ORIGIN=https://your-domain.example

# Frontend
# Leave empty when the built SPA and /api routes share one public origin through
# a reverse proxy. Set this before npm run build:web when the API is on a
# different origin.
VITE_API_BASE_URL=

# PostgreSQL
# Required. Persistent state must use PostgreSQL.
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require
DATABASE_MAX_CONNECTIONS=5

# Ideavibes auth proxy
# Required for sign-in and protected API routes.
MCTAI_AUTH_URL=https://auth.mctai.app
MCTAI_AUTH_APP_TOKEN=app_your_app_token
MCTAI_AUTH_JWKS_URL=https://auth.mctai.app/.well-known/jwks.json

# Ideavibes email proxy
# Required for invite and operator-alert email delivery. OPERATOR_ALERT_EMAIL is
# optional but recommended for scheduled publisher failure alerts.
MCTAI_EMAIL_URL=https://email.mctai.app/send
MCTAI_EMAIL_APP_TOKEN=email_your_app_token
OPERATOR_ALERT_EMAIL=operator@example.com

# Object storage
# Required for rendered assets, source media caching, and Instagram publishing.
OBJECT_STORAGE_ENDPOINT=https://object-storage.example.com
OBJECT_STORAGE_REGION=auto
OBJECT_STORAGE_BUCKET=your-bucket
OBJECT_STORAGE_ACCESS_KEY_ID=your-access-key-id
OBJECT_STORAGE_SECRET_ACCESS_KEY=your-secret-access-key
OBJECT_STORAGE_PREFIX=barbara-sh-b010-vancouver-puls

# Instagram Graph API
# Required to connect and publish to an Instagram Business/Creator account.
INSTAGRAM_APP_ID=your-instagram-app-id
INSTAGRAM_APP_SECRET=your-instagram-app-secret
INSTAGRAM_REDIRECT_URI=https://your-domain.example/settings
INSTAGRAM_GRAPH_API_VERSION=v20.0
INSTAGRAM_ACCESS_TOKEN=your-secure-instagram-graph-token
INSTAGRAM_BUSINESS_ACCOUNT_ID=17841400000000000
INSTAGRAM_USERNAME=your_instagram_username

# Claude
# Required for AI draft generation/regeneration.
ANTHROPIC_API_KEY=sk-ant-your-api-key
